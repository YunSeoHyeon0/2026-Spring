        function setItem(item) {
            selectedItem = item;
            updateButton('item', item);
        }

        function setSize(size) {
            selectedSize = size;
            updateButton('size', size);
        }

        function setStyle(style) {
            selectedStyle = style;
            updateButton('style', style);
        }

        function updateButton(type, value) {
            document.querySelectorAll('.option-btn').forEach(btn => {
                let btnText = btn.textContent.trim();
                let matchText = '';
                
                if (type === 'item') {
                    const itemNames = { clothes: '옷', books: '책', cosmetics: '화장품', accessories: '악세서리' };
                    matchText = itemNames[value];
                } else if (type === 'size') {
                    const sizeNames = { small: '4-7평', large: '7-12평' };
                    matchText = sizeNames[value];
                } else if (type === 'style') {
                    const styleNames = { vintage: '빈티지', minimal: '미니멀', modern: '모던' };
                    matchText = styleNames[value];
                }

                if (btnText === matchText) {
                    btn.classList.add('selected');
                } else if (type === 'item' && selectedItem !== item) {
                    const items = ['clothes', 'books', 'cosmetics', 'accessories'];
                    if (items.some(i => btnText.includes(i))) {
                        btn.classList.remove('selected');
                    }
                } else if (type === 'size' && selectedSize !== size) {
                    if (btnText.includes('평')) {
                        btn.classList.remove('selected');
                    }
                } else if (type === 'style' && selectedStyle !== style) {
                    const styles = ['빈티지', '미니멀', '모던'];
                    if (styles.includes(btnText)) {
                        btn.classList.remove('selected');
                    }
                }
            });
        }

        function getRecommendation() {
            if (!selectedItem || !selectedSize || !selectedStyle) {
                alert('모든 항목을 선택해주세요!');
                return;
            }

            const key = `${selectedItem}_${selectedSize}_${selectedStyle}`;
            const rec = recommendations[key];

            if (rec) {
                displayResult(rec);
            } else {
                alert('추천 정보를 찾을 수 없습니다.');
            }
        }

        function displayResult(rec) {
            let html = `
                <div class="recommendation-card">
                    <h3>📌 당신의 선택</h3>
                    <div class="info-text">${rec.items}</div>
                    <p style="margin-bottom: 15px; color: #555;">${rec.reason}</p>
                </div>

                <div class="recommendation-card">
                    <h3>🛒 추천 상품</h3>
            `;

            rec.products.forEach((product, index) => {
                html += `
                    <div class="product-item">
                        <div class="product-name">${index + 1}. ${product.name}</div>
                        <a href="${product.link}" target="_blank" class="product-link">네이버 스마트스토어에서 보기</a>
                    </div>
                `;
            });

            html += `
                </div>
            `;

            document.getElementById('recommendationResult').innerHTML = html;
            document.getElementById('formSection').style.display = 'none';
            document.getElementById('resultSection').classList.add('show');
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function resetForm() {
            selectedItem = '';
            selectedSize = '';
            selectedStyle = '';

            document.querySelectorAll('.option-btn').forEach(btn => {
                btn.classList.remove('selected');
            });

            document.getElementById('formSection').style.display = 'block';
            document.getElementById('resultSection').classList.remove('show');
            document.getElementById('recommendationResult').innerHTML = '';
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
    </script>
</body>
</html>
