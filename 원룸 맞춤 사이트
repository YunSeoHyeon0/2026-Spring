                    { name: '모던 대형 뷰티 수납장', link: 'https://smartstore.naver.com/search?q=모던+화장품+수납장' },
                    { name: '세련된 디스플레이 선반', link: 'https://smartstore.naver.com/search?q=모던+화장품+선반' }
                ],
