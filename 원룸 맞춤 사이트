                products: [
                    { name: '빈티지 대형 악세서리 디스플레이', link: 'https://smartstore.naver.com/search?q=빈티지+악세서리+디스플레이' },
                    { name: '앤틱 수집장', link: 'https://smartstore.naver.com/search?q=앤틱+악세서리+선반' }
                ],
